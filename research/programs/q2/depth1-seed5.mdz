# q2-depth1-seed5

$v0 = 6
$v1 = 2
$v2 = "blue"
IF $v0 < 9 THEN
  Say $v1
END
FOR $v3 IN [7, 7, 6, 0, 4, 3, 8, 2, 7, 7]
  Say $v3
END
FOR $v4 IN [0, 7, 2, 2, 1, 4, 9, 2, 0, 8]
  Say $v4
END
$v5 = 10
WHILE $v5 != 0
  Say $v5
  $v5 = $v5 - 1
END
CASE $v2
WHEN "ok"
  $v6 = 7
WHEN "hold"
  Say $v0
  Say $v1
ELSE
  Say $v2
  $v7 = $v5 + 1
END
